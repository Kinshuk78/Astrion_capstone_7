# ── Astrion DQ — Environment Configuration ────────────────────────────────────
# Copy this file to config/.env and fill in your values.
# The .env file is gitignored — never commit real API keys.

# ── OpenRouter (LLM-powered executive summaries) ─────────────────────────────
# OpenRouter gives access to Claude, GPT-4o, Gemini, Llama and others via one key.
# Get your key: https://openrouter.ai/keys
# Without this key the system works fully — the summariser falls back to
# the deterministic markdown template.
OPENROUTER_API_KEY=your-key-here

# Model to use for executive summaries. OpenRouter model IDs:
#   anthropic/claude-sonnet-4-6   -- best reasoning, moderate cost
#   openai/gpt-4o                 -- fast, good for short summaries
#   meta-llama/llama-3.3-70b-instruct:free  -- free tier, good quality
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# Maximum issues passed to LLM for the executive summary (cost vs coverage)
LLM_TOP_N=5

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the DuckDB warehouse file (relative to project root)
DUCKDB_PATH=data/processed/retail.duckdb

# ── Workflow defaults ─────────────────────────────────────────────────────────
# Default sensitivity for detectors: normal | high
# "high" uses tighter thresholds for maximum issue detection coverage.
DETECTION_SENSITIVITY=high

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING
LOG_LEVEL=INFO
