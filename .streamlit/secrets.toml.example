# Streamlit Community Cloud secrets.
# Keep OPENROUTER_API_KEY only on the Render API service, not here.

# Required for remote AI features from Streamlit Cloud.
ASTRION_API_URL = "https://astrion-dq-api.onrender.com"

# Optional: only needed when the Render API is protected by a Bearer token.
ASTRION_API_TOKEN = "replace-with-your-render-api-token"

# Optional: set this only if you want a login prompt on the Streamlit UI itself.
ASTRION_DASHBOARD_TOKEN = "replace-with-a-separate-dashboard-password"
