# Optional secrets for Streamlit Community Cloud.
# Paste these into the app's "Advanced settings" -> "Secrets" box.

# Optional: enables LLM summaries and the SQL Assistant tab.
OPENROUTER_API_KEY = "sk-or-v1-your-key-here"

# Optional: if set, the dashboard shows a login prompt and requires this token.
ASTRION_API_TOKEN = "replace-with-a-random-shared-token"
